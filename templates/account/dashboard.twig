{% extends "layout.twig" %}

{% block title %}Usuário da Conta{% endblock %}

{% block content %}
<div class="row">
    <div class="col-lg-4">
        <div class="card shadow-sm mb-4">
            <div class="card-header">
                <strong>Resumo da Conta</strong>
            </div>
            <div class="card-body">
                <p><strong>ID:</strong> {{ selectedAccount.id }}</p>
                <p><strong>Nome:</strong> {{ selectedAccount.name }}</p>
                <p><strong>Saldo:</strong> R$ {{ selectedAccount.balance|number_format(2, ',', '.') }}</p>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="row">
            <div class="col-md-6">
                <div class="card shadow-sm mb-4">
                    <div class="card-header"><strong>Creditar</strong></div>
                    <div class="card-body">
                        <form method="post" action="/account/credit">
                            <div class="mb-3">
                                <label class="form-label">Valor</label>
                                <input type="number" step="0.01" name="amount" class="form-control" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Descrição</label>
                                <input type="text" name="description" class="form-control">
                            </div>
                            <button type="submit" class="btn btn-success">Creditar</button>
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card shadow-sm mb-4">
                    <div class="card-header"><strong>Debitar</strong></div>
                    <div class="card-body">
                        <form method="post" action="/account/debit">
                            <div class="mb-3">
                                <label class="form-label">Valor</label>
                                <input type="number" step="0.01" name="amount" class="form-control" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Descrição</label>
                                <input type="text" name="description" class="form-control">
                            </div>
                            <button type="submit" class="btn btn-danger">Debitar</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-header"><strong>Transferir</strong></div>
            <div class="card-body">
                <form method="post" action="/account/transfer">
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Conta destino</label>
                            <select name="to_account_id" class="form-select" required>
                                <option value="">Selecione</option>
                                {% for item in accounts %}
                                    {% if item.id != selectedAccount.id %}
                                        <option value="{{ item.id }}">{{ item.id }} - {{ item.name }}</option>
                                    {% endif %}
                                {% endfor %}
                            </select>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label class="form-label">Valor</label>
                            <input type="number" step="0.01" name="amount" class="form-control" required>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label class="form-label">Descrição</label>
                            <input type="text" name="description" class="form-control">
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary">Transferir</button>
                </form>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-header"><strong>Extrato</strong></div>
            <div class="card-body">
                {% if statement is empty %}
                    <p class="text-muted mb-0">Nenhuma movimentação encontrada.</p>
                {% else %}
                    <div class="table-responsive">
                        <table class="table table-bordered align-middle">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Tipo</th>
                                    <th>Valor</th>
                                    <th>Descrição</th>
                                    <th>Relacionada</th>
                                    <th>Data</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for tx in statement %}
                                    <tr>
                                        <td>{{ tx.id }}</td>
                                        <td>{{ tx.type }}</td>
                                        <td>R$ {{ tx.amount|number_format(2, ',', '.') }}</td>
                                        <td>{{ tx.description ?: '-' }}</td>
                                        <td>
                                            {% if tx.related_account_id %}
                                                Conta {{ tx.related_account_id }}
                                            {% else %}
                                                -
                                            {% endif %}
                                        </td>
                                        <td>{{ tx.created_at }}</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}