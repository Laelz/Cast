<div class="row g-3">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <p class="text-muted mb-1">
                    <i class="bi bi-plus-circle me-1"></i>
                    Créditos
                </p>
                <div class="fs-5 fw-bold text-success">
                    R$ {{ credits_total|number_format(2, ',', '.') }}
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <p class="text-muted mb-1">
                    <i class="bi bi-dash-circle me-1"></i>
                    Débitos
                </p>
                <div class="fs-5 fw-bold text-danger">
                    R$ {{ debits_total|number_format(2, ',', '.') }}
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <p class="text-muted mb-1">
                    <i class="bi bi-list-ul me-1"></i>
                    Movimentações
                </p>
                <div class="fs-5 fw-bold text-dark">
                    {{ statement|length }}
                </div>
            </div>
        </div>
    </div>
</div>