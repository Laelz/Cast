<div class="modal fade" id="transferModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post"
                  action="/account/transfer"
                  class="submit-once-form"
                  onsubmit="return confirm('Deseja realmente realizar esta transferência?');">
                <div class="modal-header">
                    <h5 class="modal-title">Transferir valor</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

                    <div class="mb-3">
                        <label class="form-label">Conta destino</label>
                        <select name="to_account_id" class="form-select" required>
                            <option value="">Selecione</option>
                            {% for item in accounts %}
                                {% if item.id != selectedAccount.id %}
                                    <option value="{{ item.id }}">{{ item.id }} - {{ item.name }}</option>
                                {% endif %}
                            {% endfor %}
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Valor</label>
                        <div class="input-group">
                            <span class="input-group-text">R$</span>
                            <input type="text"
                                name="amount"
                                class="form-control money-input"
                                placeholder="0,00"
                                inputmode="decimal"
                                required>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Descrição</label>
                        <input type="text" name="description" class="form-control">
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary submit-once-btn">Confirmar transferência</button>
                </div>
            </form>
        </div>
    </div>
</div>