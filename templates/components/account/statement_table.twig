<div class="card shadow-sm border-0 mt-4">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <strong>Extrato</strong>
        <span class="badge bg-light text-dark">{{ pagination.total }} movimentações</span>
    </div>
    <div class="card-body">
        {% if statement is empty %}
            <p class="text-muted mb-0">Nenhuma movimentação encontrada para os filtros selecionados.</p>
        {% else %}
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Tipo</th>
                            <th>Valor</th>
                            <th>Descrição</th>
                            <th>Relacionada</th>
                            <th>Data</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for tx in statement %}
                            <tr>
                                <td>{{ tx.id }}</td>
                                <td>
                                    {% if tx.type == 'credit' %}
                                        <span class="badge bg-success">
                                            <i class="bi bi-plus-circle me-1"></i>Crédito
                                        </span>
                                    {% elseif tx.type == 'debit' %}
                                        <span class="badge bg-danger">
                                            <i class="bi bi-dash-circle me-1"></i>Débito
                                        </span>
                                    {% elseif tx.type == 'transfer_in' %}
                                        <span class="badge bg-primary">
                                            <i class="bi bi-arrow-down-left-circle me-1"></i>Recebida
                                        </span>
                                    {% elseif tx.type == 'transfer_out' %}
                                        <span class="badge bg-warning text-dark">
                                            <i class="bi bi-arrow-up-right-circle me-1"></i>Enviada
                                        </span>
                                    {% else %}
                                        <span class="badge bg-secondary">{{ tx.type }}</span>
                                    {% endif %}
                                </td>
                                <td class="fw-semibold">
                                    {% if tx.type in ['debit', 'transfer_out'] %}
                                        <span class="text-danger">- R$ {{ tx.amount|number_format(2, ',', '.') }}</span>
                                    {% else %}
                                        <span class="text-success">+ R$ {{ tx.amount|number_format(2, ',', '.') }}</span>
                                    {% endif %}
                                </td>
                                <td>{{ tx.description ?: '-' }}</td>
                                <td>
                                    {% if tx.related_account_id %}
                                        Conta {{ tx.related_account_id }}
                                    {% else %}
                                        -
                                    {% endif %}
                                </td>
                                <td>{{ tx.created_at }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            {% include 'components/account/statement_pagination.twig' with {
                pagination: pagination,
                filters: filters
            } %}
        {% endif %}
    </div>
</div>