<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Banco Digital{% endblock %}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet"
    >
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand" href="/">Banco Digital</a>

            <div class="ms-auto d-flex align-items-center gap-3 text-white">
                {% if auth %}
                    <span>{{ auth.email }} ({{ auth.role }})</span>
                    <a href="/logout" class="btn btn-sm btn-light">Sair</a>
                {% else %}
                    <a href="/login" class="btn btn-sm btn-light">Entrar</a>
                {% endif %}
            </div>
        </div>
    </nav>

    <main class="container py-4">
        {% if flash %}
            <div class="alert alert-{{ flash.type }} alert-dismissible fade show" role="alert">
                {{ flash.message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endif %}

        {% block content %}{% endblock %}
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>