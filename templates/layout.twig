<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Banco Digital{% endblock %}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet"
    >
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand" href="/">Banco Digital</a>

            <div class="ms-auto d-flex align-items-center gap-2">
                {% if auth %}
                    {% if auth.role == 'admin' %}
                        <a href="/admin" class="btn btn-sm btn-light">Admin</a>
                        <a href="/account" class="btn btn-sm btn-outline-light">Minha Conta</a>
                    {% endif %}

                    <span class="text-white small ms-2">{{ auth.email }}</span>
                    <a href="/logout" class="btn btn-sm btn-light">Sair</a>
                {% else %}
                    <a href="/login" class="btn btn-sm btn-light">Entrar</a>
                {% endif %}
            </div>
        </div>
    </nav>

    <main class="container py-4">
        {% include 'components/flash_alert.twig' %}
        {% block content %}{% endblock %}
    </main>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.money-input').forEach(function (input) {
                input.addEventListener('input', function () {
                    input.value = input.value.replace(/[^0-9.,]/g, '');
                });

                input.addEventListener('blur', function () {
                    let value = input.value.trim();

                    if (value === '') {
                        return;
                    }

                    value = value.replace(/\./g, '').replace(',', '.');

                    const parsed = parseFloat(value);

                    if (!isNaN(parsed) && parsed > 0) {
                        input.value = parsed.toLocaleString('pt-BR', {
                            minimumFractionDigits: 2,
                            maximumFractionDigits: 2
                        });
                    }
                });
            });

            document.querySelectorAll('.submit-once-form').forEach(function (form) {
                form.addEventListener('submit', function () {
                    const moneyInputs = form.querySelectorAll('.money-input');

                    moneyInputs.forEach(function (input) {
                        let value = input.value.trim();

                        if (value === '') {
                            return;
                        }

                        value = value.replace(/\./g, '').replace(',', '.');

                        const parsed = parseFloat(value);

                        if (!isNaN(parsed) && parsed > 0) {
                            input.value = parsed.toFixed(2);
                        }
                    });

                    const button = form.querySelector('.submit-once-btn');

                    if (button) {
                        button.disabled = true;
                        button.innerText = 'Processando...';
                    }
                });
            });
        });
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>